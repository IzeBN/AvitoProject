# ==============================================================
# AvitoСRM — пример конфигурации окружения
# Скопируй в .env и заполни своими значениями
# ==============================================================

# --------------------------------------------------------------
# Приложение
# --------------------------------------------------------------
APP_NAME=AvitoСRM
# development | staging | production
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=info

# --------------------------------------------------------------
# База данных PostgreSQL (asyncpg)
# Формат: postgresql+asyncpg://user:password@host:port/dbname
# --------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://avitocrm:secret@localhost:5432/avitocrm

# Размер основного пула соединений
DATABASE_POOL_SIZE=20
# Максимальное переполнение пула (итого до 100 соединений)
DATABASE_MAX_OVERFLOW=80

# --------------------------------------------------------------
# Redis
# Формат: redis://:password@host:port/db
# --------------------------------------------------------------
REDIS_URL=redis://:secret@localhost:6379/0

# Размер пула соединений Redis
REDIS_POOL_SIZE=20

# --------------------------------------------------------------
# Безопасность
# --------------------------------------------------------------
# Секретный ключ для подписи JWT — минимум 32 случайных символа
# Сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_generate_with_secrets_token_hex_32

# Ключ шифрования AES-256 — ровно 64 hex-символа (32 байта)
# Сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=change_me_64_hex_chars_for_aes256_encryption_key_here_00000000

# Ключ для HMAC-SHA256 поиска по телефону — 32+ случайных символа
# Сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
SEARCH_HASH_KEY=change_me_search_hash_key_for_hmac_phone_search_here_0000000000

# Время жизни access токена (минуты)
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Время жизни refresh токена (дни)
REFRESH_TOKEN_EXPIRE_DAYS=30

# --------------------------------------------------------------
# SMTP — отправка email уведомлений (все поля опциональны)
# --------------------------------------------------------------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASSWORD=your_smtp_password
SMTP_FROM_NAME=AvitoСRM
# Использовать STARTTLS
SMTP_TLS=true
# Использовать SSL/TLS (не совместимо с SMTP_TLS=true)
SMTP_SSL=false

# --------------------------------------------------------------
# Суперадмин — создаётся автоматически при первом запуске
# --------------------------------------------------------------
SUPERADMIN_EMAIL=admin@avitocrm.local
# Пароль будет захеширован при старте
SUPERADMIN_PASSWORD=change_me_strong_password

# --------------------------------------------------------------
# ARQ — очередь задач (опционально)
# Если не задан — используется REDIS_URL
# --------------------------------------------------------------
# ARQ_REDIS_URL=redis://:secret@localhost:6379/1
