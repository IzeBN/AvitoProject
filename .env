# ==============================================================
# AvitoСRM — пример конфигурации окружения
# Скопируй в .env и заполни своими значениями
# ==============================================================

# --------------------------------------------------------------
# Приложение
# --------------------------------------------------------------
APP_NAME=responsCRM
# development | staging | production
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=info

# --------------------------------------------------------------
# База данных PostgreSQL (asyncpg)
# Формат: postgresql+asyncpg://user:password@host:port/dbname
# --------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://responscrm:vn7Y-ZtYtW7B-L@postgres:5432/responscrm

# Размер основного пула соединений
DATABASE_POOL_SIZE=20
# Максимальное переполнение пула (итого до 100 соединений)
DATABASE_MAX_OVERFLOW=80

# --------------------------------------------------------------
# Redis
# Формат: redis://:password@host:port/db
# --------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# Размер пула соединений Redis
REDIS_POOL_SIZE=20

# --------------------------------------------------------------
# Безопасность
# --------------------------------------------------------------
# Секретный ключ для подписи JWT — минимум 32 случайных символа
# Сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=d9fe80c03df539daf8ce8d78975bb6eaaff3e4fd1deaa18270d4775b5bea86df

# Ключ шифрования AES-256 — ровно 64 hex-символа (32 байта)
# Сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=909b9ff2a5dd747989df3d0fae7c77fc038376160e7fad0ae82c29bb3351fc93

# Ключ для HMAC-SHA256 поиска по телефону — 32+ случайных символа
# Сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
SEARCH_HASH_KEY=1a81c702ef48825d4db4d8da578580ed8f050f6df7a91d3a5a23c42c837e46ba

# Время жизни access токена (минуты)
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Время жизни refresh токена (дни)
REFRESH_TOKEN_EXPIRE_DAYS=30

# --------------------------------------------------------------
# SMTP — отправка email уведомлений (все поля опциональны)
# --------------------------------------------------------------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASSWORD=your_smtp_password
SMTP_FROM_NAME=responsCRM
# Использовать STARTTLS
SMTP_TLS=true
# Использовать SSL/TLS (не совместимо с SMTP_TLS=true)
SMTP_SSL=false

# --------------------------------------------------------------
# Суперадмин — создаётся автоматически при первом запуске
# --------------------------------------------------------------
SUPERADMIN_EMAIL=admin@responscrm.ru
# Пароль будет захеширован при старте
SUPERADMIN_PASSWORD=rootxx

# --------------------------------------------------------------
# ARQ — очередь задач (опционально)
# Если не задан — используется REDIS_URL
# --------------------------------------------------------------
ARQ_REDIS_URL=redis://redis:6379/1

# PostgreSQL container credentials (используется docker-compose для инициализации)
POSTGRES_USER=responscrm
POSTGRES_PASSWORD=vn7Y-ZtYtW7B-L
POSTGRES_DB=responscrm
